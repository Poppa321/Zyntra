EXPO_PUBLIC_API_BASE_URL=https://zyntra-5wo1.onrender.com/api

# Google Sign-In — create OAuth client IDs at console.cloud.google.com
# (APIs & Services > Credentials). The Web client ID is required; iOS/Android
# ones are optional but recommended for a production build on each platform.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

